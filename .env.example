# Copy this file to .env and fill in your values before running docker compose.
# docker compose automatically loads .env from the project root.

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-secret

# ── AI model ─────────────────────────────────────────────────────────────────
# Any model available in Ollama's library: https://ollama.com/library
OLLAMA_MODEL=llama3.2

# ── Ports ─────────────────────────────────────────────────────────────────────
# Port the frontend nginx is published on the host
FRONTEND_PORT=80
